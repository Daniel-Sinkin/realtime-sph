// shaders/realtime_sph_reset.comp
#version 450

layout(local_size_x = 128) in;

struct SimParams
{
    vec4 domain_min_dt;
    vec4 domain_max_radius;
    vec4 gravity_rest_density;
    vec4 kernel_poly6_spiky;
    vec4 pbf_params;
    vec4 viscosity_vorticity;
    uvec4 counts;
    uvec4 grid_size;
};

struct SimStats
{
    uint escaped;
    uint overflow;
    uint active_count;
    uint nan_count;
    uint max_neighbors;
    uint max_speed_milli;
    int sum_position_x_milli;
    int sum_position_y_milli;
    int sum_position_z_milli;
    int sum_velocity_x_milli;
    int sum_velocity_y_milli;
    int sum_velocity_z_milli;
    int min_position_x_milli;
    int min_position_y_milli;
    int min_position_z_milli;
    int max_position_x_milli;
    int max_position_y_milli;
    int max_position_z_milli;
    uint invalid_events;
    uint overflow_events;
};

layout(std430, set = 0, binding = 4) buffer CellCounts
{
    uint cell_counts[];
};
layout(std430, set = 0, binding = 6) readonly buffer ParamsBuffer
{
    SimParams params;
};
layout(std430, set = 0, binding = 7) buffer StatsBuffer
{
    SimStats stats;
};
layout(std430, set = 0, binding = 12) buffer RigidImpulses
{
    ivec4 rigid_impulses[];
};

void main()
{
    const uint id = gl_GlobalInvocationID.x;
    if (id < params.counts.y)
    {
        cell_counts[id] = 0u;
    }
    if (id < params.grid_size.w)
    {
        const uint base = 2u * id;
        rigid_impulses[base] = ivec4(0);
        rigid_impulses[base + 1u] = ivec4(0);
    }
    if (id == 0u)
    {
        stats.escaped = 0u;
        stats.overflow = 0u;
        stats.active_count = params.counts.x;
        stats.nan_count = 0u;
        stats.max_neighbors = 0u;
        stats.max_speed_milli = 0u;
        stats.sum_position_x_milli = 0;
        stats.sum_position_y_milli = 0;
        stats.sum_position_z_milli = 0;
        stats.sum_velocity_x_milli = 0;
        stats.sum_velocity_y_milli = 0;
        stats.sum_velocity_z_milli = 0;
        stats.min_position_x_milli = 2147483647;
        stats.min_position_y_milli = 2147483647;
        stats.min_position_z_milli = 2147483647;
        stats.max_position_x_milli = -2147483647;
        stats.max_position_y_milli = -2147483647;
        stats.max_position_z_milli = -2147483647;
        stats.invalid_events = 0u;
        stats.overflow_events = 0u;
    }
}
