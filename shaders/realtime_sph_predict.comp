// shaders/realtime_sph_predict.comp
#version 450

layout(local_size_x = 128) in;

struct SimParams
{
    vec4 domain_min_dt;
    vec4 domain_max_radius;
    vec4 gravity_rest_density;
    vec4 kernel_poly6_spiky;
    vec4 pbf_params;
    vec4 viscosity_vorticity;
    uvec4 counts;
    uvec4 grid_size;
};

struct SimStats
{
    uint escaped;
    uint overflow;
    uint active_count;
    uint nan_count;
    uint max_neighbors;
    uint max_speed_milli;
    int sum_position_x_milli;
    int sum_position_y_milli;
    int sum_position_z_milli;
    int sum_velocity_x_milli;
    int sum_velocity_y_milli;
    int sum_velocity_z_milli;
    int min_position_x_milli;
    int min_position_y_milli;
    int min_position_z_milli;
    int max_position_x_milli;
    int max_position_y_milli;
    int max_position_z_milli;
    uint invalid_events;
    uint overflow_events;
};

struct RigidBody
{
    vec4 center_type;
    vec4 extent_radius;
    vec4 velocity_inv_mass;
    vec4 orientation;
};

layout(std430, set = 0, binding = 0) buffer Positions
{
    vec4 positions_radius[];
};
layout(std430, set = 0, binding = 1) buffer PreviousDensity
{
    vec4 previous_density[];
};
layout(std430, set = 0, binding = 2) buffer VelocityLambda
{
    vec4 velocity_lambda[];
};
layout(std430, set = 0, binding = 3) buffer DeltaNeighbors
{
    vec4 delta_neighbors[];
};
layout(std430, set = 0, binding = 6) readonly buffer ParamsBuffer
{
    SimParams params;
};
layout(std430, set = 0, binding = 7) buffer StatsBuffer
{
    SimStats stats;
};
layout(std430, set = 0, binding = 11) readonly buffer RigidBodies
{
    RigidBody rigid_bodies[];
};
layout(std430, set = 0, binding = 12) buffer RigidImpulses
{
    ivec4 rigid_impulses[];
};

const uint RIGID_SHAPE_SPHERE = 0u;
const uint RIGID_SHAPE_BOX = 1u;
const float RIGID_IMPULSE_SCALE = 100000.0;

bool invalid_vec3(vec3 v)
{
    return any(isnan(v)) || any(isinf(v));
}

vec3 respawn_position(uint id)
{
    const vec3 span = params.domain_max_radius.xyz - params.domain_min_dt.xyz;
    const float fx = float((id * 73u) % 997u) / 997.0;
    const float fy = float((id * 191u) % 991u) / 991.0;
    return vec3(
        params.domain_min_dt.x + (0.20 + 0.60 * fx) * span.x,
        params.domain_min_dt.y + (0.20 + 0.60 * fy) * span.y,
        params.domain_max_radius.z - max(4.0 * params.domain_max_radius.w, 0.18)
    );
}

vec3 rotate_by_quat(vec3 value, vec4 quat)
{
    return value + 2.0 * cross(quat.xyz, cross(quat.xyz, value) + quat.w * value);
}

vec3 rotate_by_inverse_quat(vec3 value, vec4 quat)
{
    return rotate_by_quat(value, vec4(-quat.xyz, quat.w));
}

float signed_axis(float value)
{
    return value < 0.0 ? -1.0 : 1.0;
}

bool sphere_collision(
    vec3 x,
    float particle_radius,
    RigidBody body,
    out vec3 correction,
    out vec3 contact_point
)
{
    const vec3 r = x - body.center_type.xyz;
    const float combined_radius = particle_radius + body.extent_radius.w;
    const float dist2 = dot(r, r);
    if (dist2 >= combined_radius * combined_radius)
    {
        correction = vec3(0.0);
        contact_point = body.center_type.xyz;
        return false;
    }
    const float dist = sqrt(max(dist2, 1.0e-12));
    const vec3 normal = dist > 1.0e-6 ? r / dist : vec3(0.0, 0.0, 1.0);
    correction = normal * (combined_radius - dist);
    contact_point = body.center_type.xyz + normal * body.extent_radius.w;
    return true;
}

bool box_collision(
    vec3 x,
    float particle_radius,
    RigidBody body,
    out vec3 correction,
    out vec3 contact_point
)
{
    const vec3 half_extent = max(body.extent_radius.xyz, vec3(1.0e-4));
    const vec3 local = rotate_by_inverse_quat(x - body.center_type.xyz, body.orientation);
    const vec3 closest = clamp(local, -half_extent, half_extent);
    const vec3 diff = local - closest;
    const float dist2 = dot(diff, diff);
    if (dist2 > 1.0e-12)
    {
        const float dist = sqrt(dist2);
        if (dist >= particle_radius)
        {
            correction = vec3(0.0);
            contact_point = body.center_type.xyz + rotate_by_quat(closest, body.orientation);
            return false;
        }
        correction = rotate_by_quat((diff / dist) * (particle_radius - dist), body.orientation);
        contact_point = body.center_type.xyz + rotate_by_quat(closest, body.orientation);
        return true;
    }

    const vec3 face_distance = half_extent - abs(local);
    vec3 normal = vec3(signed_axis(local.x), 0.0, 0.0);
    vec3 contact_local = local;
    contact_local.x = normal.x * half_extent.x;
    float penetration = face_distance.x;
    if (face_distance.y < penetration)
    {
        normal = vec3(0.0, signed_axis(local.y), 0.0);
        contact_local = local;
        contact_local.y = normal.y * half_extent.y;
        penetration = face_distance.y;
    }
    if (face_distance.z < penetration)
    {
        normal = vec3(0.0, 0.0, signed_axis(local.z));
        contact_local = local;
        contact_local.z = normal.z * half_extent.z;
        penetration = face_distance.z;
    }
    correction = rotate_by_quat(normal * (particle_radius + penetration), body.orientation);
    contact_point = body.center_type.xyz + rotate_by_quat(contact_local, body.orientation);
    return true;
}

void accumulate_rigid_impulse(
    uint body_index,
    vec3 body_center,
    vec3 contact_point,
    vec3 correction
)
{
    const vec3 body_correction = -correction;
    const vec3 torque = cross(contact_point - body_center, body_correction);
    const ivec3 packed = ivec3(clamp(
        body_correction * RIGID_IMPULSE_SCALE,
        vec3(-2000000000.0),
        vec3(2000000000.0)
    ));
    const ivec3 packed_torque = ivec3(clamp(
        torque * RIGID_IMPULSE_SCALE,
        vec3(-2000000000.0),
        vec3(2000000000.0)
    ));
    const uint base = 2u * body_index;
    atomicAdd(rigid_impulses[base].x, packed.x);
    atomicAdd(rigid_impulses[base].y, packed.y);
    atomicAdd(rigid_impulses[base].z, packed.z);
    atomicAdd(rigid_impulses[base].w, 1);
    atomicAdd(rigid_impulses[base + 1u].x, packed_torque.x);
    atomicAdd(rigid_impulses[base + 1u].y, packed_torque.y);
    atomicAdd(rigid_impulses[base + 1u].z, packed_torque.z);
}

vec3 apply_rigid_collisions(vec3 x, float particle_radius)
{
    const uint body_count = params.grid_size.w;
    for (uint body_index = 0u; body_index < body_count; ++body_index)
    {
        const RigidBody body = rigid_bodies[body_index];
        const uint shape = uint(body.center_type.w + 0.5);
        vec3 correction = vec3(0.0);
        vec3 contact_point = body.center_type.xyz;
        bool hit = false;
        if (shape == RIGID_SHAPE_SPHERE)
        {
            hit = sphere_collision(x, particle_radius, body, correction, contact_point);
        }
        else
        {
            hit = box_collision(x, particle_radius, body, correction, contact_point);
        }
        if (!hit)
        {
            continue;
        }
        x += correction;
        accumulate_rigid_impulse(body_index, body.center_type.xyz, contact_point, correction);
    }
    return x;
}

void main()
{
    const uint id = gl_GlobalInvocationID.x;
    if (id >= params.counts.x)
    {
        return;
    }

    const float dt = params.domain_min_dt.w;
    const float radius = params.domain_max_radius.w;
    const vec3 lower = params.domain_min_dt.xyz + vec3(radius);
    const vec3 upper = params.domain_max_radius.xyz - vec3(radius);

    vec4 position_radius = positions_radius[id];
    vec4 current_velocity_lambda = velocity_lambda[id];
    previous_density[id] = vec4(position_radius.xyz, 0.0);
    delta_neighbors[id] = vec4(0.0);

    vec3 v = current_velocity_lambda.xyz + params.gravity_rest_density.xyz * dt;
    vec3 x = position_radius.xyz + v * dt;

    if (invalid_vec3(x) || invalid_vec3(v)
        || any(lessThan(x, params.domain_min_dt.xyz - vec3(0.25)))
        || any(greaterThan(x, params.domain_max_radius.xyz + vec3(0.25))))
    {
        x = respawn_position(id);
        v = vec3(0.0);
        atomicAdd(stats.escaped, 1u);
        atomicAdd(stats.invalid_events, 1u);
        if (invalid_vec3(position_radius.xyz) || invalid_vec3(current_velocity_lambda.xyz))
        {
            atomicAdd(stats.nan_count, 1u);
        }
    }

    x = clamp(x, lower, upper);
    if (params.grid_size.w > 0u)
    {
        x = apply_rigid_collisions(x, radius);
        x = clamp(x, lower, upper);
    }
    positions_radius[id] = vec4(x, radius);
    velocity_lambda[id] = vec4(v, 0.0);
}
